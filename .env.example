# Workshop environment file. Copy to `.env` and fill in:
#
#   cp .env.example .env
#
# Then have your AI coding agent run `./setup/install-workshop.sh --yes`.

# Your IBM entitlement key for cp.icr.io. Get one from
#   https://myibm.ibm.com/products-services/containerlibrary
# It is a JWT-shaped string (~190 chars). Treat it like a password.
IBM_ENTITLEMENT_KEY=
